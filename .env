APP_NAME=Webby
APP_ENV=production
APP_KEY=base64:cGxhY2Vob2xkZXJrZXlmb3J3ZWJieWluc3RhbGxlcjE=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://webby-edited-production.up.railway.app

# Sentry Error Reporting Endpoint
APP_SENTRY=https://sentry.titansys.dev

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DAILY_DAYS=14
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

QUEUE_CONNECTION=sync
CACHE_STORE=database
FILESYSTEM_DISK=local

VITE_APP_NAME="${APP_NAME}"

# NOTE: App configurations (Pusher/Reverb, Firebase, social login, email, builders, etc.)
# are managed via Admin Panel (/admin/*), not .env
